{
  "manifest_version": 3,
  "name": "TMDB 夸克网盘影视重命名",
  "version": "1.0.0",
  "description": "使用 TMDB + 本地AI智能解析 自动重命名夸克网盘中的影视文件",
  "permissions": ["activeTab", "scripting", "storage", "cookies"],
  "host_permissions": [
    "https://api.themoviedb.org/*",
    "https://pan.quark.cn/*",
    "https://drive-pc.quark.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://pan.quark.cn/*", "*://drive-pc.quark.cn/*", "*://b.quark.cn/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}